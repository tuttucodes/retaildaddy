# Required
SARVAM_API_KEY=
PRODUCT_URL=http://localhost:3000

# Required only for Meet mode
GOOGLE_MEET_URL=

# Sarvam models and voice
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_STT_LANGUAGE_CODE=ml-IN
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_LANGUAGE_CODE=ml-IN
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_PACE=1.04
SARVAM_CHAT_MODEL=sarvam-105b

# Identity and behavior
AGENT_NAME=RetailDaddy AI Demo Agent
DISCLOSE_AI=true
DEMO_SCRIPT_PATH=demo/demo-script.example.json
PRODUCT_KB_PATH=demo/product-knowledge.example.md

# Browser automation
CHROME_PROFILE_DIR=./playwright-profile
BROWSER_CHANNEL=
MEET_DISPLAY_NAME=RetailDaddy AI Demo Agent
MEET_AUTO_PRESENT=true
MEET_SAVE_DIAGNOSTICS=true
MEET_DIAGNOSTICS_DIR=./.meet-diagnostics
DESKTOP_CAPTURE_SOURCE=RetailDaddy Agent Stage
AGENT_STAGE_TITLE=RetailDaddy Agent Stage
HEADLESS=false

# Audio routing
# On macOS, afplay is used by default. To inject speech into Meet, route output into
# a virtual microphone (BlackHole/Loopback) and select that device in Meet.
AUDIO_OUT_DIR=./audio-out
AUDIO_PLAY_COMMAND=
AUDIO_AUTO_LISTEN=false
MEET_CAPTION_LISTEN=false
MEET_CAPTION_POLL_MS=700
BROWSER_AUDIO_PLAYBACK=false

# Optional question ingestion. Drop WAV/MP3/WEBM files here and run:
#   npm run agent -- listen-audio
AUDIO_INPUT_DIR=./recordings

# Optional STT capture command for advanced users. The command should write audio
# files into AUDIO_INPUT_DIR or stdout raw audio if you extend src/audioCapture.js.
# Required for strict launch preflight. Azure run script supplies a PulseAudio default.
AUDIO_CAPTURE_COMMAND=
