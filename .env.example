# Required
SARVAM_API_KEY=
PRODUCT_URL=http://localhost:3000

# Required only for Meet mode
GOOGLE_MEET_URL=

# Sarvam models and voice
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_STT_LANGUAGE_CODE=ml-IN
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_LANGUAGE_CODE=ml-IN
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_PACE=1.04
SARVAM_TTS_SAMPLE_RATE=24000
SARVAM_CHAT_MODEL=sarvam-105b

# Identity and behavior
AGENT_NAME=RetailDaddy AI Demo Agent
DISCLOSE_AI=true
DEMO_SCRIPT_PATH=demo/demo-script.example.json
PRODUCT_KB_PATH=demo/product-knowledge.example.md

# Calling agent
CALL_AGENT_NAME=RetailDaddy AI Calling Agent
CALL_AGENT_PERSONA_NAME=Asha
CALL_AGENT_HOST=0.0.0.0
CALL_AGENT_PORT=4180
CALL_PUBLIC_BASE_URL=
CALL_PROVIDER=twilio
CALL_AGENT_TRANSPORT=stream
CALL_AGENT_MULTILINGUAL=true
CALL_AGENT_TRANSFER_PHONE=
CALL_AGENT_CHAT_MODEL=sarvam-30b
CALL_AGENT_MAX_TOKENS=95
CALL_AGENT_TEMPERATURE=0.42
CALL_RECORD_MAX_LENGTH=7
CALL_RECORD_TIMEOUT=1
CALL_AGENT_TTS_SPEAKER=shubh
CALL_AGENT_TTS_PACE=1.08
CALL_AGENT_TTS_SAMPLE_RATE=8000
CALL_STREAM_STT_ENABLED=true
CALL_STREAM_TTS_ENABLED=true
CALL_STREAM_VAD_RMS=0.008
CALL_STREAM_SILENCE_MS=650
CALL_STREAM_MIN_SPEECH_MS=220
CALL_STREAM_MAX_SPEECH_MS=9000
CALL_STREAM_FALLBACK_TRANSCRIPT_MS=900
CALL_STREAM_TTS_MIN_BUFFER_SIZE=20
CALL_STREAM_TTS_MAX_CHUNK_LENGTH=90
CALL_AGENT_GOAL=qualify retail store leads, answer RetailDaddy questions, capture the caller need, and move interested callers toward a product demo or human follow-up

# Required only for outbound phone calls through Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_FROM_NUMBER=

# Browser automation
CHROME_PROFILE_DIR=./playwright-profile
BROWSER_CHANNEL=
MEET_DISPLAY_NAME=RetailDaddy AI Demo Agent
MEET_AUTO_PRESENT=true
MEET_SAVE_DIAGNOSTICS=true
MEET_DIAGNOSTICS_DIR=./.meet-diagnostics
DESKTOP_CAPTURE_SOURCE=RetailDaddy Agent Stage
AGENT_STAGE_TITLE=RetailDaddy Agent Stage
HEADLESS=false

# Audio routing
# On macOS, afplay is used by default. To inject speech into Meet, route output into
# a virtual microphone (BlackHole/Loopback) and select that device in Meet.
AUDIO_OUT_DIR=./audio-out
AUDIO_PLAY_COMMAND=
AUDIO_STREAM_COMMAND=
AUDIO_STREAM_SAMPLE_RATE=16000
AUDIO_AUTO_LISTEN=false
MEET_CAPTION_LISTEN=false
MEET_CAPTION_POLL_MS=700
BROWSER_AUDIO_PLAYBACK=false

# Optional question ingestion. Drop WAV/MP3/WEBM files here and run:
#   npm run agent -- listen-audio
AUDIO_INPUT_DIR=./recordings

# Optional fallback STT capture command for advanced users. The command should
# write complete audio files into AUDIO_INPUT_DIR.
AUDIO_CAPTURE_COMMAND=

# Low-latency Meet listening. Prefer this over AUDIO_CAPTURE_COMMAND when your
# Meet output is routed into a virtual capture device. The command must write
# mono signed 16-bit little-endian PCM at AUDIO_STREAM_SAMPLE_RATE to stdout.
# macOS/BlackHole example:
# AUDIO_STREAM_COMMAND='ffmpeg -hide_banner -nostdin -loglevel warning -f avfoundation -i ":BlackHole 2ch" -ac 1 -ar 16000 -f s16le -acodec pcm_s16le pipe:1'
# Linux/PulseAudio example:
# AUDIO_STREAM_COMMAND='ffmpeg -hide_banner -nostdin -loglevel warning -f pulse -i rd_meet_out.monitor -ac 1 -ar 16000 -f s16le -acodec pcm_s16le pipe:1'

# Persona (shared) — human, no AI disclosure
DISCLOSE_AI=false
CALL_AGENT_TTS_SPEAKER=anushka

# Box 1 optional email-the-Meet-link
CALL_EMAIL_LINK=false
GOOGLE_AGENT_CLIENT_ID=
GOOGLE_AGENT_CLIENT_SECRET=
GOOGLE_AGENT_REFRESH_TOKEN=
GOOGLE_AGENT_EMAIL=retaildaddy.demo@gmail.com
GOOGLE_AGENT_CALENDAR_ID=primary

# Box 2 barge-in
MEET_VAD_RMS=0.008
MEET_SILENCE_MS=650
MEET_JOIN_RETRIES=1
